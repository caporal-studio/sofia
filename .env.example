SOFIA_LLM_PROVIDER=ollama
SOFIA_APP_BASE_URL=http://localhost:8501
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
SOFIA_EMBEDDING_PROVIDER=ollama
SOFIA_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Use only if you choose OpenAI in Settings.
# OPENAI_API_KEY=<your-openai-key>
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_SUMMARY_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

OLLAMA_SUMMARY_MODEL=llama3.1:8b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=2048
OLLAMA_DISABLE_THINKING=true
SOFIA_MAX_CONTEXT_TOKENS=5000
SOFIA_MAX_PROMPT_TOKENS=8000
SOFIA_MAX_RESPONSE_TOKENS=2048
SOFIA_CONVERSATION_HISTORY_PAIRS=3
SOFIA_SUMMARIZE_RETRIEVED_CONTEXT=false
SOFIA_TABULAR_ANALYSIS_MODE=auto

# Optional: SMTP for password recovery.
# SOFIA_SMTP_HOST=smtp.example.com
# SOFIA_SMTP_PORT=465
# SOFIA_SMTP_USER=user@example.com
# SOFIA_SMTP_PASSWORD=app-password
# SOFIA_SMTP_FROM=noreply@example.com
